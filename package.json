{
  "name": "cycle",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "desktop:build": "pnpm --filter @cycle/desktop build",
    "desktop:dev": "pnpm --filter @cycle/desktop dev",
    "desktop:start": "pnpm --filter @cycle/desktop start",
    "desktop:typecheck": "pnpm --filter @cycle/desktop typecheck",
    "storybook": "pnpm --filter @cycle/ui storybook",
    "storybook:build": "pnpm --filter @cycle/ui storybook:build",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "oxlint --deny-warnings packages",
    "lint:fix": "oxlint --fix packages",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@types/node": "^25.9.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.3"
}
